      "Bash(python3:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(while read f)",
      "Bash(do head -20 \"$f\")",
      "Bash(echo:*)",
      "Bash(done)",
      "Bash(cat:*)",
      "Bash(xargs:*)",
      "Bash(jar xf:*)",
      "Bash(jar tf:*)",
      "Bash(javap:*)",
      "Bash(test:*)"
